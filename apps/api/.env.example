PORT=8080
ENV=development
# Active store: file-based SQLite (no external services needed).
SQLITE_PATH=ridenow.db
# For the Postgres path (docker compose / Colima), point modules here instead.
DATABASE_URL=postgres://ridenow:ridenow@localhost:5432/ridenow?sslmode=disable
REDIS_ADDR=localhost:6379

# Razorpay — get test keys from dashboard.razorpay.com (Settings → API Keys).
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_secret_here
RAZORPAY_WEBHOOK_SECRET=optional_webhook_secret
